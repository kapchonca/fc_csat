{
  "version": "0.1-payment-and-loan",
  "templates": [
    {
      "task": "payment_inquiry",
      "user_goal": "Find out what happened to a specific payment and open a support case only if the payment status suggests one is needed.",
      "target_action": "get_status_payment",
      "downstream_action": "create_payment_inquiry",
      "base_trace": [
        "verify_customer_session",
        "get_status_payment",
        "create_payment_inquiry",
        "done"
      ],
      "conditions": [
        "correct",
        "skip_step",
        "skip_step_not_recovered",
        "extra_step",
        "wrong_order",
        "wrong_order_not_recovered",
        "wrong_tool",
        "wrong_tool_not_recovered",
        "wrong_parameter",
        "wrong_parameter_not_recovered"
      ]
    },
    {
      "task": "loan_payment_allocation",
      "user_goal": "Understand how a specific loan payment was split across principal, interest, fees, and other charges after checking the loan context that explains the allocation.",
      "target_action": "get_status_loan",
      "downstream_action": "get_loan_payment_allocation",
      "base_trace": [
        "verify_customer_session",
        "get_status_loan",
        "get_loan_payment_allocation",
        "done"
      ],
      "conditions": [
        "correct",
        "skip_step",
        "skip_step_not_recovered",
        "extra_step",
        "wrong_order",
        "wrong_order_not_recovered",
        "wrong_tool",
        "wrong_tool_not_recovered",
        "wrong_parameter",
        "wrong_parameter_not_recovered"
      ]
    }
  ]
}
